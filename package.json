{
  "name": "@polarsignals/pprof",
  "version": "0.1.3",
  "description": "Node.js profiling library that automatically uploads heap profiles to Polar Signals",
  "main": "index.js",
  "files": [
    "*.js",
    "*.ts"
  ],
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "publish:ci": "lerna publish --yes --no-verify-access"
  },
  "keywords": [
    "profiling",
    "pprof",
    "heap",
    "memory",
    "performance",
    "polar-signals",
    "observability"
  ],
  "author": "Polar Signals",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/polarsignals/pprof-nodejs.git"
  },
  "bugs": {
    "url": "https://github.com/polarsignals/pprof-nodejs/issues"
  },
  "homepage": "https://github.com/polarsignals/pprof-nodejs#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "provenance": true
  },
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@datadog/pprof": "^5.14.0",
    "pprof-format": "^2.2.1"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "lerna": "9.0.7",
    "typescript": "^5.9.3"
  },
  "optionalDependencies": {
    "express": "^4.21.2"
  }
}
