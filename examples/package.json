{
  "name": "@polarsignals/pprof-examples",
  "version": "0.0.0",
  "private": true,
  "description": "Example apps for testing @polarsignals/pprof",
  "scripts": {
    "build": "node build.mjs",
    "typecheck": "tsc --noEmit",
    "strip-maps": "find dist -name '*.js.map' -delete",
    "example": "node dist/example.js",
    "example:express": "node dist/example-express.js"
  },
  "dependencies": {
    "@polarsignals/pprof": "link:.."
  },
  "devDependencies": {
    "@polarsignals/sourcemap-esbuild-plugin": "^0.1.6",
    "@types/express": "^4.17.21",
    "@types/node": "^24.7.2",
    "esbuild": "^0.24.0",
    "express": "^4.21.2",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
